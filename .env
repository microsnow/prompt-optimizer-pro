# ============ 开发环境配置 ============

# API 代理服务器地址（前端调用后端的地址）
VITE_API_BASE=http://localhost:3001

# 代理服务器内部地址
VITE_API_PROXY_URL=http://localhost:3001

# ============ 前端配置 ============

# 应用名称
VITE_APP_NAME=PromptOptimizer Pro

# 应用版本
VITE_APP_VERSION=1.0.0

# ============ 生产环境配置 ============

# 生产环境 API 代理地址（部署时使用）
# VITE_API_PROXY_URL=https://ai-agent.citgroup.cn
