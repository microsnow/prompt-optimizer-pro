# ============ 开发环境配置 ============

# API 代理服务器地址（前端调用后端的地址）
VITE_API_BASE=http://localhost:3001

# 代理服务器内部地址
VITE_API_PROXY_URL=http://localhost:3001

# ============ 前端配置 ============

# 应用名称
VITE_APP_NAME=PromptOptimizer Pro

# 应用版本
VITE_APP_VERSION=1.0.0

# ============ 生产环境配置 ============

# 生产环境 API 代理地址（部署时使用）
# VITE_API_PROXY_URL=https://ai-agent.citgroup.cn

# ============ 外部 API 配置（后端对外接口） ============

# 是否启用远程 API 配置源（true: 从后端 API 加载，false: 使用本地 JSON）
VITE_USE_REMOTE_CONFIG=true

# 外部 API 基础地址
VITE_EXTERNAL_API_BASE=http://localhost:8080

# 外部 API 鉴权凭证
VITE_EXTERNAL_APP_ID=
# AppSecret 的 SHA256 哈希值（64位十六进制），直接作为 HMAC 密钥
VITE_EXTERNAL_APP_SECRET_HASH=

# 是否使用后端 AI Proxy（true: 走 RuoYi 后端代理，false: 走本地 Express 代理）
VITE_USE_BACKEND_PROXY=true
