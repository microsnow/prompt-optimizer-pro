# ============ 环境配置 ============
# 复制此文件为 .env 或 .env.production，根据环境填入具体值

# 运行环境：development | production
NODE_ENV=development

# ============ CORS 配置 ============
# 允许的请求源（多个源用逗号分隔，无空格）
# 开发环境
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,file://

# 生产环境示例
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://app.yourdomain.com

# ============ API 代理服务器 ============
# 代理服务器监听端口
API_PROXY_PORT=3001

# ============ 日志配置 ============
# 日志级别：trace | debug | info | warn | error
LOG_LEVEL=info

# 日志输出位置
LOG_DIR=./logs

# ============ 第三方 API 密钥 ============
# 可选：如果在服务器端存储 API 密钥，这里配置
# 注意：不要提交到 Git 仓库，添加到 .gitignore

# Qwen API Key（可选，如果客户端提供则不需要）
# QWEN_API_KEY=sk-xxx

# OpenAI API Key（可选，支持多个 AI 提供商）
# OPENAI_API_KEY=sk-xxx

# ============ 特殊配置 ============
# 请求超时时间（毫秒）
REQUEST_TIMEOUT=60000

# 最大请求体大小
MAX_REQUEST_SIZE=50mb

# 缓存配置（可选）
ENABLE_CACHE=false
CACHE_TTL=300

# ============ 安全配置 ============
# API 速率限制（请求/分钟）
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# 是否需要 API Key 认证
REQUIRE_AUTH=false

# JWT Secret（如果使用认证）
# JWT_SECRET=your-secret-key-here
