{
  "name": "prompt-optimizer-pro",
  "version": "1.0.0",
  "description": "AI 提示词生成、优化和管理平台",
  "main": "dist/main.cjs",
  "type": "module",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:win": "npm run build && node scripts/package.cjs --win",
    "build:mac": "npm run build && node scripts/package.cjs --mac",
    "build:linux": "npm run build && node scripts/package.cjs --linux",
    "test": "npm run test:api",
    "test:api": "node test-api.js",
    "test:quick": "echo '快速测试' && npm run build:win",
    "api:proxy": "node src/server/api-proxy.js",
    "api:proxy:py": "conda run -n python311 python src/server/api-proxy.py",
    "start": "concurrently \"npm run api:proxy:py\" \"npm run dev\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "date-fns": "^2.30.0",
    "dexie": "^3.2.4",
    "express": "^5.2.1",
    "pinia": "^2.1.3",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.37",
    "@vitejs/plugin-vue": "^4.2.3",
    "concurrently": "^8.1.0",
    "electron": "^25.1.0",
    "electron-builder": "^24.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.3",
    "vite": "^4.3.9",
    "vue-tsc": "^1.8.2",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.promptoptimizer.app",
    "productName": "PromptOptimizer Pro",
    "files": [
      "dist/**/*",
      "src/server/**/*",
      "node_modules/express/**/*",
      "node_modules/cors/**/*",
      "node_modules/axios/**/*",
      "node_modules/pinia/**/*",
      "node_modules/vue/**/*",
      "node_modules/date-fns/**/*",
      "node_modules/dexie/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist-release-v4"
    },
    "win": {
      "target": [
        "portable"
      ],
      "certificateFile": null
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
