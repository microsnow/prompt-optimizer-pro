# ============================================================
# Nginx 配置示例 - 完整版
# ============================================================
# 放置于: /etc/nginx/sites-available/your-app.conf
# 启用: sudo ln -s /etc/nginx/sites-available/your-app.conf \
#                 /etc/nginx/sites-enabled/your-app.conf
# 重启: sudo systemctl reload nginx
# ============================================================

# ============================================================
# 1. HTTP 自动跳转 HTTPS
# ============================================================
server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com www.yourdomain.com;

    # 重定向所有请求到 HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }

    # Let's Encrypt 验证（保持 HTTP）
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
}

# ============================================================
# 2. HTTPS 主配置
# ============================================================
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name yourdomain.com www.yourdomain.com;

    # ============ SSL/TLS 配置 ============
    # Let's Encrypt 证书
    ssl_certificate /etc/letsencrypt/live/yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yourdomain.com/privkey.pem;

    # SSL 协议和加密
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5:!3DES;
    ssl_prefer_server_ciphers on;
    ssl_ecdh_curve prime256v1:secp384r1;

    # SSL 会话配置
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    # OCSP Stapling (可选)
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 8.8.8.8 8.8.4.4;

    # ============ 日志配置 ============
    # 访问日志
    access_log /var/log/nginx/your-app.access.log combined;
    
    # 错误日志
    error_log /var/log/nginx/your-app.error.log warn;

    # ============ 性能优化 ============
    # 最大上传文件大小
    client_max_body_size 50M;
    
    # Gzip 压缩
    gzip on;
    gzip_types text/plain text/css text/xml text/javascript 
               application/x-javascript application/xml+rss 
               application/json application/javascript;
    gzip_min_length 1000;
    gzip_comp_level 6;
    gzip_vary on;

    # ============ 代理超时 ============
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # ============================================================
    # 3. 前端静态资源（根路径）
    # ============================================================
    location / {
        # 应用文件根目录
        root /var/www/html/your-app;
        
        # 首先尝试请求的文件
        # 其次尝试目录
        # 都不存在则返回 index.html (SPA 路由)
        try_files $uri $uri/ /index.html;

        # 不缓存 HTML 和 index.html
        location ~* ^/(?:index\.html)?$ {
            add_header Cache-Control "no-cache, no-store, must-revalidate";
            expires -1;
        }

        # 缓存 JavaScript
        location ~* \.js$ {
            expires 7d;
            add_header Cache-Control "public, immutable";
            add_header X-Content-Type-Options "nosniff";
        }

        # 缓存 CSS
        location ~* \.css$ {
            expires 7d;
            add_header Cache-Control "public, immutable";
            add_header Content-Type "text/css; charset=utf-8";
        }

        # 缓存图片和字体
        location ~* \.(png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot|otf)$ {
            expires 30d;
            add_header Cache-Control "public, immutable";
            access_log off;
        }

        # 其他资源缓存
        location ~* \.(txt|md|manifest|json)$ {
            expires 1d;
            add_header Cache-Control "public, max-age=86400";
        }
    }

    # ============================================================
    # 4. API 代理（关键部分）
    # ============================================================
    location /api {
        # 反向代理到 Node.js 应用
        proxy_pass http://localhost:3001;

        # HTTP 版本
        proxy_http_version 1.1;

        # ============ 请求头转发 ============
        # 原始主机
        proxy_set_header Host $host;
        
        # 真实客户端 IP
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        
        # 协议和端口
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_set_header X-Forwarded-Port $server_port;

        # 转发原始请求 URL
        proxy_set_header X-Original-URL $scheme://$http_host$request_uri;

        # ============ WebSocket 支持 ============
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # ============ 代理缓冲 ============
        # 禁用缓冲，实时转发 (适合流式响应)
        proxy_buffering off;
        proxy_cache_bypass $http_upgrade;

        # 如果启用缓冲，配置缓冲大小
        # proxy_buffer_size 128k;
        # proxy_buffers 4 256k;

        # ============ 超时配置 ============
        # 连接后端的超时
        proxy_connect_timeout 60s;
        
        # 发送请求的超时
        proxy_send_timeout 60s;
        
        # 读取响应的超时
        proxy_read_timeout 300s;  # 适合流式和长时间请求

        # ============ 错误处理 ============
        proxy_intercept_errors on;
        error_page 502 503 504 @backend_error;
    }

    # ============================================================
    # 5. 速率限制（防 DDoS）
    # ============================================================
    # 定义速率限制区域
    # (需要在 http 块中定义，这里仅作参考)
    
    # 应用到 API 端点
    # location /api {
    #     limit_req zone=api_limit burst=20 nodelay;
    #     # ... 其他配置
    # }

    # ============================================================
    # 6. 健康检查端点
    # ============================================================
    location /health {
        proxy_pass http://localhost:3001/health;
        
        # 不记录健康检查日志
        access_log off;
        
        # 超时较短
        proxy_connect_timeout 5s;
        proxy_read_timeout 5s;
    }

    # ============================================================
    # 7. 日志查看端点（可选，添加密码保护）
    # ============================================================
    location /logs {
        # 基础身份验证（使用 htpasswd 生成）
        # auth_basic "API Logs";
        # auth_basic_user_file /etc/nginx/.htpasswd;

        proxy_pass http://localhost:3001/logs;
        access_log /var/log/nginx/logs-api.log combined;
    }

    # ============================================================
    # 8. 后端错误处理
    # ============================================================
    location @backend_error {
        default_type application/json;
        return 502 '{"error":"Service unavailable","status":502}';
    }

    # ============================================================
    # 9. 禁用的位置
    # ============================================================
    # 禁止访问 .git 目录
    location /.git {
        deny all;
        access_log off;
        log_not_found off;
    }

    # 禁止访问 .env 等敏感文件
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # 禁止访问备份文件
    location ~ \.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist)$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # ============================================================
    # 10. 安全响应头
    # ============================================================
    # 强制 HTTPS（HSTS）
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    # 防止 MIME 类型嗅探
    add_header X-Content-Type-Options "nosniff" always;

    # 防止点击劫持
    add_header X-Frame-Options "SAMEORIGIN" always;

    # 防止 XSS 攻击
    add_header X-XSS-Protection "1; mode=block" always;

    # Referrer 政策
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # CSP (Content Security Policy) - 可选
    # add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';" always;

    # ============================================================
    # 11. 额外优化
    # ============================================================
    # 禁用 Nginx 版本显示
    server_tokens off;

    # 启用 HTTP/2 Push (可选)
    # 推送关键资源
    # http2_push /assets/main.js;
    # http2_push /assets/main.css;

    # 启用 QUIC (HTTP/3) - 需要编译支持
    # add_header Alt-Svc 'h3=":443"; ma=86400';
}

